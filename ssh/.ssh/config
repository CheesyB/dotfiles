Host gitlab.maibornwolff.de
  HostName gitlab.maibornwolff.de
  User git
  IdentityFile ~/.ssh/gitlab-mw
  IdentitiesOnly yes
  Port 22

Host pi 
  HostName exporter-cm4.local
  User pi
  PubkeyAuthentication yes
  IdentityFile ~/.ssh/exporter_cm4.pub
  StrictHostKeyChecking no

Host cm4
  HostName 192.168.0.100
  User root
  ProxyJump pi
  ForwardAgent yes
  PubkeyAuthentication yes
  IdentityFile ~/.ssh/cm4
  StrictHostKeyChecking no

Host guest
  HostName 192.168.0.102
  User root
  ForwardAgent yes
  StrictHostKeyChecking no
  ProxyJump cm4
  IdentityFile ~/.ssh/cm4
  IdentitiesOnly yes
  PubkeyAuthentication yes
  PubkeyAcceptedAlgorithms +ssh-rsa
  HostkeyAlgorithms +ssh-rsa


Host github.com-traton
    HostName github.com
    IdentityFile ~/.ssh/work-github
    IdentitiesOnly yes
   
